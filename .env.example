# ============================================================
# MedGuard AI — .env.example
# Copy to .env and fill in your values
# ============================================================

# ── App ─────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change-me-super-secret-key
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# ── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://medguard:medguard@postgres:5432/medguard
REDIS_URL=redis://redis:6379/0

# ── Kafka ───────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_DETECTION_TOPIC=medical_detections
KAFKA_ALERT_TOPIC=emergency_alerts

# ── ML Models ───────────────────────────────────────────────
MODEL_DIR=/app/models
YOLO_POSE_MODEL=yolov8n-pose.pt        # auto-downloaded by ultralytics
ACTION_MODEL_PATH=/app/models/action_classifier.pt
ANOMALY_MODEL_PATH=/app/models/anomaly_detector.pt
DETECTION_CONFIDENCE=0.65
ALERT_COOLDOWN_SECONDS=30

# ── Camera Sources ──────────────────────────────────────────
# 0 = webcam, or RTSP URL for CCTV
CAMERA_SOURCES=0
# CAMERA_SOURCES=rtsp://user:pass@192.168.1.100:554/stream1,0

# ── LLM (choose one) ────────────────────────────────────────
LLM_PROVIDER=ollama             # ollama | openai | anthropic
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3

# Uncomment for OpenAI fallback:
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# ── Embeddings ──────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
VECTOR_DB=chroma                # chroma | faiss
CHROMA_PERSIST_DIR=/app/chroma_db

# ── Alerting ────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxx
TWILIO_AUTH_TOKEN=xxxx
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

SENDGRID_API_KEY=SG.xxxx
ALERT_EMAIL_FROM=alerts@medguard.ai

FIREBASE_CREDENTIALS_PATH=/app/firebase-credentials.json

# ── MLflow ──────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000

# ── GPS / Location ──────────────────────────────────────────
DEFAULT_LATITUDE=28.6139
DEFAULT_LONGITUDE=77.2090
